{
  "name": "@ironmussa/funny",
  "version": "0.1.14",
  "private": false,
  "description": "Local and team workspace for orchestrating coding agents across isolated git worktrees",
  "license": "MIT",
  "author": "Anthropic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ironmussa/funny.git"
  },
  "bin": {
    "funny": "bin/funny.js",
    "funny-runtime": "packages/runtime/bin/funny-server.js",
    "funny-server": "packages/server/bin/funny-server.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "bin",
    "packages/server/dist",
    "packages/runtime/dist",
    "packages/client/dist"
  ],
  "scripts": {
    "start": "bun ./bin/funny.js",
    "dev": "concurrently --kill-others -n server,runner,client,sched -c blue,green,yellow,magenta \"bun run dev:server\" \"bun run dev:runtime\" \"bun run dev:client\" \"bun run dev:scheduler\"",
    "portless:routes": "portless alias funny 5173 --force && portless alias api.funny 5002 --force && portless alias runner.funny 3003 --force",
    "portless:list": "portless list",
    "dev:portless": "bun run portless:routes && bun run dev",
    "dev:server": "cd packages/server && bun --env-file ../../.env --watch src/index.ts",
    "dev:runtime": "cd packages/runtime && bun --env-file ../../.env src/dev-watch.ts",
    "dev:client": "cd packages/client && npx vite",
    "dev:scheduler": "bun --env-file ./.env --watch packages/scheduler/src/bin/scheduler.ts",
    "dev:api-acp": "bun --watch --cwd packages/api-acp src/index.ts",
    "run": "concurrently --kill-others -n server,runner,client -c blue,green,yellow \"bun run run:server\" \"bun run run:runtime\" \"bun run run:client\"",
    "run:server": "cd packages/server && bun --env-file ../../.env src/index.ts",
    "run:runtime": "bun --env-file ../../.env --cwd packages/runtime src/index.ts",
    "run:client": "cd packages/client && npx vite --no-clearScreen",
    "build": "bun run --cwd packages/client build && bun run --cwd packages/runtime build && bun run --cwd packages/server build",
    "build:railway": "bun install && bun run build",
    "start:railway": "cd packages/server && bun run start",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "db:push": "bun run --cwd packages/runtime db:push",
    "db:studio": "bun run --cwd packages/runtime db:studio",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:native": "bun run --cwd packages/native-git build",
    "build:native:debug": "bun run --cwd packages/native-git build:debug",
    "build:sidecar": "bun scripts/build-sidecar.ts",
    "bench:markdown": "bun packages/client/scripts/benchmark-markdown-renderers.ts",
    "bench:markdown:browser": "bun packages/client/scripts/benchmark-markdown-wasm-browser.ts",
    "profile:client": "bun scripts/profile-client.ts",
    "test": "bun scripts/run-tests.ts",
    "prepare": "husky",
    "security:check": "npm run security:secrets && npm run security:audit",
    "security:secrets": "npx secretlint \"**/*\"",
    "security:audit": "bun audit --audit-level=moderate",
    "security:snyk": "npx snyk test --all-projects",
    "lint": "oxlint . && bun run fitness:boundary-validation && bun run fitness:query-validation && bun run fitness:socket-validation && bun run fitness:json-validation",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "codegen": "bunx playwright codegen http://localhost:5173",
    "fitness": "bun run fitness:layering && bun run fitness:circular && bun run fitness:size",
    "fitness:layering": "bun scripts/fitness/check-layering.ts",
    "fitness:circular": "bun scripts/fitness/check-circular.ts",
    "fitness:size": "bun scripts/fitness/check-file-size.ts",
    "fitness:growth": "bun scripts/fitness/check-file-growth.ts",
    "fitness:boundary-validation": "bun scripts/fitness/check-boundary-validation.ts",
    "fitness:boundary-validation:refresh": "bun scripts/fitness/check-boundary-validation.ts --refresh",
    "fitness:boundary-validation:test": "bun scripts/fitness/check-boundary-validation.ts --self-test",
    "fitness:query-validation": "bun scripts/fitness/check-query-boundary-validation.ts",
    "fitness:query-validation:refresh": "bun scripts/fitness/check-query-boundary-validation.ts --refresh",
    "fitness:query-validation:test": "bun scripts/fitness/check-query-boundary-validation.ts --self-test",
    "fitness:socket-validation": "bun scripts/fitness/check-socket-boundary-validation.ts",
    "fitness:socket-validation:refresh": "bun scripts/fitness/check-socket-boundary-validation.ts --refresh",
    "fitness:socket-validation:test": "bun scripts/fitness/check-socket-boundary-validation.ts --self-test",
    "fitness:json-validation": "bun scripts/fitness/check-json-boundary-validation.ts",
    "fitness:json-validation:refresh": "bun scripts/fitness/check-json-boundary-validation.ts --refresh",
    "fitness:json-validation:test": "bun scripts/fitness/check-json-boundary-validation.ts --self-test",
    "typecheck": "bun scripts/fitness/check-typecheck.ts",
    "typecheck:refresh": "bun scripts/fitness/check-typecheck.ts --refresh",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@anthropic-ai/claude-agent-sdk": "^0.3.179",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/openai": "^1.4.7",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "better-auth": "^1.6.19",
    "deepagents-acp": "^0.1.12",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.25",
    "nanoid": "^5.0.9",
    "neverthrow": "^8.2.0",
    "nodemailer": "^9.0.1",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint-plugin-zod": "4.7.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "react-doctor": "^0.7.2",
    "secretlint": "^13.0.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^7.0.2",
    "vitepress": "^2.0.0-alpha.17"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0",
    "playwright": "^1.61.0"
  },
  "resolutions": {
    "dompurify": "^3.4.11",
    "esbuild": ">=0.28.1",
    "prosemirror-model": "^1.25.9",
    "uuid": "^11.1.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=22.19.0 <23"
  },
  "packageManager": "bun@1.3.10"
}
