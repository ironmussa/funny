# Client dev server port
VITE_PORT=5179

# Host to bind the dev server (default: 127.0.0.1, use 0.0.0.0 for remote access)
VITE_HOST=0.0.0.0

# Backend server port (used in Tauri mode and dev proxy for API and WebSocket)
# For team mode, set this to the central server port (e.g. 3002)
VITE_SERVER_PORT=3005

# Full backend server URL (for production/deployed setups where the server is on a different host)
# When set, overrides VITE_SERVER_PORT for API and WebSocket connections.
# Example: VITE_SERVER_URL=https://funny-server.example.com
# VITE_SERVER_URL=
