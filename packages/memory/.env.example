# ── Server ────────────────────────────────────────────────
PP_PORT=4020
PP_PROJECT_ID=default
PP_PROJECT_NAME=default

# ── Database (libSQL / Turso) ─────────────────────────────
PP_DB_URL=file:memory.db
# PP_SYNC_URL=libsql://your-db.turso.io
# PP_AUTH_TOKEN=your-turso-auth-token

# ── LLM (used for consolidation / summarisation) ─────────
PP_LLM_URL=http://localhost:4010
PP_LLM_MODEL=claude-haiku
# PP_LLM_API_KEY=sk-ant-...

# ── Embeddings ────────────────────────────────────────────
# Provider: "openai" | "ollama" | leave unset for built-in
# MEMORY_EMBEDDING_PROVIDER=openai

# OpenAI (when provider = openai)
# OPENAI_API_KEY=sk-...

# Ollama (when provider = ollama)
# MEMORY_OLLAMA_URL=http://localhost:11434
# MEMORY_OLLAMA_MODEL=nomic-embed-text
