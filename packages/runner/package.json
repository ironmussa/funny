{
  "name": "@funny/runner",
  "version": "0.1.0",
  "private": false,
  "description": "Local runner agent for funny — executes git operations and Claude agents on the user's machine, reporting back to a central server.",
  "license": "MIT",
  "bin": {
    "funny-runner": "./bin/funny-runner.js"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun run build.ts",
    "start": "bun run dist/index.js",
    "test": "bun test"
  },
  "dependencies": {
    "@funny/core": "*",
    "@funny/shared": "*",
    "hono": "^4.11.9",
    "neverthrow": "^8.2.0",
    "nanoid": "^5.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "typescript": "^5.8.2"
  },
  "optionalDependencies": {
    "@openai/codex-sdk": "^0.101.0",
    "node-pty": "^1.1.0"
  },
  "engines": {
    "bun": ">=1.3.5"
  }
}
